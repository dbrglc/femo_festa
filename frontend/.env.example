# API REST Endpoint - da ottenere dall'output CDK (HttpApiUrl)
# Formato: https://[API_ID].execute-api.[REGION].amazonaws.com/[STAGE]
PUBLIC_API_URL=https://your-api-id.execute-api.eu-south-1.amazonaws.com/dev

# WebSocket Endpoint - da ottenere dall'output CDK (WebSocketApiUrl)
# Formato: wss://[API_ID].execute-api.[REGION].amazonaws.com/[STAGE]
PUBLIC_WS_URL=wss://your-ws-id.execute-api.eu-south-1.amazonaws.com/dev

# Cognito Client ID - da ottenere dall'output CDK (ClientId)
# Nota: questo valore deve essere aggiornato in frontend/src/auth/cognito.ts
PUBLIC_COGNITO_CLIENT_ID=your-client-id-here

# Cognito Domain - Formato: femo-festa-[STAGE].auth.[REGION].amazoncognito.com
PUBLIC_COGNITO_DOMAIN=https://femo-festa-dev.auth.eu-south-1.amazoncognito.com

# Cognito Redirect URI - dove Cognito ritorna dopo il login
# Deve corrispondere a quanto configurato nel AuthStack CDK
PUBLIC_COGNITO_REDIRECT_URI=http://localhost:3000/order

# AWS Region
PUBLIC_AWS_REGION=eu-south-1
