# API REST Endpoint - da ottenere dall'output CDK (HttpApiUrl)
PUBLIC_API_URL=your-api-id.execute-api.eu-south-1.amazonaws.com/stage

# WebSocket Endpoint - da ottenere dall'output CDK (WebSocketApiUrl)
PUBLIC_WS_URL=your-websocket-api-id.execute-api.eu-south-1.amazonaws.com/stage

# Cognito Client ID - da ottenere dall'output CDK (ClientId)
PUBLIC_COGNITO_CLIENT_ID=your-client-id-here

# Cognito Domain - Formato: femo-festa-[STAGE].auth.[REGION].amazoncognito.com
PUBLIC_COGNITO_DOMAIN=your-cognito-domain-here

# Cognito Redirect URI - dove Cognito ritorna dopo il login
PUBLIC_COGNITO_REDIRECT_URI=your-redirect-uri-here

# AWS Region
PUBLIC_AWS_REGION=your-aws-region-here
