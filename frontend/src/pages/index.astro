---
import { initLeaderboard } from '../components/Leaderboard.ts';
const title = 'Classifica pubblica';
---
<!DOCTYPE html>
<html lang="it">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
  </head>
  <body>
    <main>
      <h1>{title}</h1>
      <div id="leaderboard"></div>
    </main>
    <script type="module">
      import { initLeaderboard } from '../components/Leaderboard.ts';
      initLeaderboard('#leaderboard');
    </script>
  </body>
</html>
