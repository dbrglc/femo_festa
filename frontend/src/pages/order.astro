---
import { getLoginUrl, logout, getAccessToken, parseHashToken } from '../auth/cognito.ts';
const title = 'Area ordini';
---

<!DOCTYPE html>
<html lang="it">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <style>
      body {
        font-family: system-ui, -apple-system, sans-serif;
        max-width: 600px;
        margin: 2rem auto;
        padding: 0 1rem;
      }
      
      main {
        display: flex;
        flex-direction: column;
        gap: 1.5rem;
      }
      
      button, input, label {
        padding: 0.5rem;
        font-size: 1rem;
      }
      
      button {
        background-color: #007bff;
        color: white;
        border: none;
        border-radius: 4px;
        cursor: pointer;
      }
      
      button:hover {
        background-color: #0056b3;
      }
      
      form {
        display: flex;
        flex-direction: column;
        gap: 1rem;
        padding: 1rem;
        border: 1px solid #ccc;
        border-radius: 4px;
      }
      
      label {
        display: flex;
        flex-direction: column;
        gap: 0.5rem;
      }
      
      input {
        border: 1px solid #ccc;
        border-radius: 4px;
      }
      
      #message {
        padding: 0.75rem;
        border-radius: 4px;
        font-weight: 500;
        display: none;
      }
      
      #message.success {
        background-color: #d4edda;
        color: #155724;
        border: 1px solid #c3e6cb;
        display: block;
      }
      
      #message.error {
        background-color: #f8d7da;
        color: #721c24;
        border: 1px solid #f5c6cb;
        display: block;
      }
      
      #message.loading {
        background-color: #d1ecf1;
        color: #0c5460;
        border: 1px solid #bee5eb;
        display: block;
      }
    </style>
  </head>
  <body>
    <main>
      <h1>{title}</h1>
      <button id="authButton">Login con Cognito</button>
      <form id="orderForm" style="display:none;">
        <label>
          Squadra
          <input type="text" name="teamName" required placeholder="Nome della squadra" />
        </label>
        <label>
          Punteggio
          <input type="number" name="score" required min="0" placeholder="0" />
        </label>
        <button type="submit">Invia ordine</button>
      </form>
      <div id="message"></div>
    </main>

    <script type="module">
      import { 
        getLoginUrl, 
        logout, 
        getAccessToken, 
        parseHashToken 
      } from '../auth/cognito.ts';

      // Configurazione API
      const API_BASE_URL = import.meta.env.PUBLIC_API_URL || 'https://{{REST_API_URL}}';
      const API_ENDPOINT = `${API_BASE_URL}/orders`;

      // Elementi DOM
      const authButton = document.getElementById('authButton');
      const orderForm = document.getElementById('orderForm');
      const message = document.getElementById('message');

      // Funzione per mostrare messaggi
      const showMessage = (text, type = 'info', autoClear = true) => {
        message.textContent = text;
        message.className = type;
        
        if (autoClear && type !== 'loading') {
          setTimeout(() => {
            message.textContent = '';
            message.className = '';
          }, 5000);
        }
      };

      // Funzione per aggiornare UI in base allo stato di login
      const setLoggedIn = (hasToken) => {
        if (hasToken) {
          authButton.textContent = 'Logout';
          orderForm.style.display = 'block';
        } else {
          authButton.textContent = 'Login con Cognito';
          orderForm.style.display = 'none';
        }
      };

      // Inizializzazione al caricamento pagina
      const token = parseHashToken() || getAccessToken();
      setLoggedIn(Boolean(token));

      // Handler click del bottone auth
      authButton.addEventListener('click', async () => {
        if (getAccessToken()) {
          await logout();
          setLoggedIn(false);
          showMessage('Logout effettuato', 'info');
        } else {
          window.location.href = getLoginUrl();
        }
      });

      // Handler submit del form
      orderForm.addEventListener('submit', async (event) => {
        event.preventDefault();

        const formData = new FormData(orderForm);
        const teamName = formData.get('teamName')?.toString().trim();
        const score = Number(formData.get('score'));

        // Validazione
        if (!teamName || !score) {
          showMessage('❌ Errore: Compila tutti i campi', 'error');
          return;
        }

        const accessToken = getAccessToken();
        if (!accessToken) {
          showMessage('❌ Errore: Devi essere autenticato per inviare un ordine', 'error');
          return;
        }

        // Mostra loading
        showMessage('Caricamento...', 'loading', false);
        
        try {
          const response = await fetch(API_ENDPOINT, {
            method: 'POST',
            headers: {
              'Content-Type': 'application/json',
              'Authorization': `Bearer ${accessToken}`,
            },
            body: JSON.stringify({
              teamName,
              score,
            }),
          });

          if (response.ok) {
            showMessage('✅ Ordine inviato con successo', 'success');
            orderForm.reset();
          } else {
            const errorText = await response.text();
            const errorMessage = errorText || response.statusText;
            showMessage(`❌ Errore: ${errorMessage}`, 'error');
          }
        } catch (err) {
          const errorMsg = err instanceof Error ? err.message : 'Errore sconosciuto';
          showMessage(`❌ Errore: ${errorMsg}`, 'error');
        }
      });
    </script>
  </body>
</html>
